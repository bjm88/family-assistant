# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Python tool caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/
coverage.xml

# Virtual environments
.venv
.env
.env.*
!.env.example

# Node / React
node_modules/
ui/react/dist/
ui/react/.vite/

# MediaPipe Tasks Vision assets — copied out of node_modules and
# lazy-downloaded by ui/react/scripts/copy-mediapipe-assets.mjs at
# `npm install` time. Treated like the Kokoro / InsightFace weight
# packs: regenerable, machine-specific, never committed.
ui/react/public/mediapipe/

# Uploaded family data (private — never commit)
resources/family/*
!resources/family/.gitkeep

# Scratch storage root used by ./scripts/run_tests.sh — keeps the
# integration suite from ever writing into resources/family/.
resources/_test_scratch/

# Lazy-downloaded AI model weights (hundreds of MB each — fetched on
# first use of InsightFace face recognition and Kokoro TTS).
resources/models/

# IDE / editor
.idea/
.vscode/
*.swp
*~

# Logs & tempfiles
*.log
*.bak
*.tmp
*.pid

# Runtime state from scripts/start.sh (PID files, logs)
.run/
logs/

# Postgres backups produced by scripts/db_backup.sh — contain encrypted
# secrets and personally-identifying data. Never commit.
backups/

# OS
.DS_Store
Thumbs.db
