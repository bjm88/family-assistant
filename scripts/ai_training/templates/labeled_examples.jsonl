{"user": "show me a query to count active goals per person", "decision": "FAMILY", "response": "SELECT p.first_name, COUNT(g.id) AS open_goals FROM people p LEFT JOIN goals g ON g.person_id = p.id WHERE p.family_id = :family_id GROUP BY p.id ORDER BY open_goals DESC;", "category": "sql"}

