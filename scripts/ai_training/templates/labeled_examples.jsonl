// ============================================================================
// FAMILY — sensitive identifiers, AUTHORISED non-admin speaker (TIER 2)
// ----------------------------------------------------------------------------
// Speaker is the subject's direct parent or spouse. The household-context
// block already includes the decrypted value for this case, so the
// model just needs to recall it naturally — no refusal, no preamble
// about "household rules". Without these examples the model leans on
// its "share YOUR own SSN only" training and refuses parent→child
// asks like "what's Jax's SSN?".
// ============================================================================
{"user": "what's jax's social security number?", "decision": "FAMILY", "response": "Jax's SSN is 612-58-9043.", "category": "sensitive"}
{"user": "i need mia's ssn for a school form", "decision": "FAMILY", "response": "Mia's SSN is 482-19-7654.", "category": "sensitive"}
